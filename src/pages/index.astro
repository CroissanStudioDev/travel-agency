---
import Layout from '../layouts/Layout.astro'
import HeroBanner from '../components/HeroBanner.astro'
import CountryCard from '../components/CountryCard.astro'
import RequestForm from '../components/RequestForm.astro'

// Популярные направления (потом вынесем в CMS/data)
const popularCountries = [
  { name: 'Мальдивы', slug: 'maldives', image: 'https://images.unsplash.com/photo-1514282401047-d79a71a590e8?w=800', description: 'Райские острова с белоснежными пляжами' },
  { name: 'Таиланд', slug: 'thailand', image: 'https://images.unsplash.com/photo-1528181304800-259b08848526?w=800', description: 'Экзотика, храмы и лучшие пляжи Азии' },
  { name: 'ОАЭ', slug: 'uae', image: 'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=800', description: 'Роскошь и современность Востока' },
  { name: 'Турция', slug: 'turkey', image: 'https://images.unsplash.com/photo-1541432901042-2d8bd64b4a9b?w=800', description: 'Всё включено и богатая история' },
  { name: 'Италия', slug: 'italy', image: 'https://images.unsplash.com/photo-1523906834658-6e24ef2386f9?w=800', description: 'Искусство, кухня и романтика' },
  { name: 'Греция', slug: 'greece', image: 'https://images.unsplash.com/photo-1533105079780-92b9be482077?w=800', description: 'Античность и лазурное море' },
]

// Типы отдыха
const travelTypes = [
  { icon: '🏖️', name: 'Пляжный отдых', description: 'Лучшие курорты мира' },
  { icon: '⛷️', name: 'Горнолыжный', description: 'Альпы, Кавказ, Андорра' },
  { icon: '🏛️', name: 'Экскурсионный', description: 'История и культура' },
  { icon: '💆', name: 'SPA и wellness', description: 'Отдых для души и тела' },
  { icon: '🎰', name: 'Круизы', description: 'Путешествия по морю' },
  { icon: '👨‍👩‍👧‍👦', name: 'Семейный', description: 'Отдых с детьми' },
]

// Отзывы
const reviews = [
  { name: 'Анна К.', text: 'Потрясающий сервис! Нам подобрали идеальный отель на Мальдивах. Всё было организовано безупречно.', rating: 5 },
  { name: 'Михаил С.', text: 'Третий раз обращаемся в это агентство. Всегда внимательны к деталям и предлагают лучшие варианты.', rating: 5 },
  { name: 'Елена В.', text: 'Спасибо за незабываемое путешествие в Италию! Экскурсионная программа была составлена идеально.', rating: 5 },
]
---

<Layout title="Главная">
  <!-- Hero баннер с формой -->
  <HeroBanner 
    title="Откройте мир с нами"
    subtitle="Премиум туры по всему миру. Индивидуальный подход к каждому путешествию."
    image="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920"
    showForm={true}
  />

  <!-- Популярные направления -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-4">Популярные направления</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Выберите страну мечты — мы организуем незабываемое путешествие</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {popularCountries.map(country => (
          <CountryCard {...country} />
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/countries" class="inline-flex items-center gap-2 text-[var(--color-accent)] font-semibold hover:underline">
          Все направления
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Типы отдыха -->
  <section class="py-20 bg-[var(--color-light)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-4">Виды отдыха</h2>
        <p class="text-gray-600">Подберём тур под ваши предпочтения</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {travelTypes.map(type => (
          <div class="bg-white rounded-xl p-6 text-center shadow-md hover:shadow-lg transition-shadow cursor-pointer">
            <div class="text-4xl mb-3">{type.icon}</div>
            <h3 class="font-semibold text-[var(--color-primary)] mb-1">{type.name}</h3>
            <p class="text-sm text-gray-500">{type.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Почему мы -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-4">Почему выбирают нас</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--color-secondary)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🏆</span>
          </div>
          <h3 class="font-semibold text-lg mb-2">15 лет опыта</h3>
          <p class="text-gray-600 text-sm">Работаем с 2010 года и знаем всё о путешествиях</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--color-secondary)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">✨</span>
          </div>
          <h3 class="font-semibold text-lg mb-2">Индивидуальный подход</h3>
          <p class="text-gray-600 text-sm">Каждый тур создаём под ваши пожелания</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--color-secondary)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">💎</span>
          </div>
          <h3 class="font-semibold text-lg mb-2">Премиум сервис</h3>
          <p class="text-gray-600 text-sm">Только проверенные отели и партнёры</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--color-secondary)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">📞</span>
          </div>
          <h3 class="font-semibold text-lg mb-2">Поддержка 24/7</h3>
          <p class="text-gray-600 text-sm">Всегда на связи во время вашего путешествия</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Отзывы -->
  <section class="py-20 bg-[var(--color-primary)] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Отзывы клиентов</h2>
        <p class="text-gray-300">Более 10 000 довольных путешественников</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {reviews.map(review => (
          <div class="bg-white/10 backdrop-blur rounded-xl p-6">
            <div class="flex gap-1 mb-4">
              {[...Array(review.rating)].map(() => (
                <span class="text-[var(--color-secondary)]">★</span>
              ))}
            </div>
            <p class="mb-4 text-gray-200">"{review.text}"</p>
            <p class="font-semibold">{review.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Форма заявки -->
  <RequestForm source="homepage" />
</Layout>

---
import Layout from '../../layouts/Layout.astro'
import HeroBanner from '../../components/HeroBanner.astro'
import RequestForm from '../../components/RequestForm.astro'
import countries from '../../data/countries.json'

export function getStaticPaths() {
  return countries.map(country => ({
    params: { slug: country.slug },
    props: { country }
  }))
}

const { country } = Astro.props
---

<Layout title={country.name} description={country.description}>
  <HeroBanner 
    title={country.name}
    subtitle={country.description}
    image={country.image}
  />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <!-- Основной контент -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-[var(--color-primary)] mb-6">О стране</h2>
          <p class="text-gray-700 mb-8 text-lg leading-relaxed">
            {country.description}
          </p>

          <!-- Климат -->
          <div class="bg-[var(--color-light)] rounded-xl p-6 mb-8">
            <h3 class="text-xl font-semibold text-[var(--color-primary)] mb-4 flex items-center gap-2">
              <span>🌤️</span> Климат
            </h3>
            <p class="text-gray-700">{country.climate}</p>
          </div>

          <!-- Лучшее время -->
          <div class="bg-[var(--color-light)] rounded-xl p-6 mb-8">
            <h3 class="text-xl font-semibold text-[var(--color-primary)] mb-4 flex items-center gap-2">
              <span>📅</span> Лучшее время для поездки
            </h3>
            <p class="text-gray-700 font-medium text-lg">{country.bestTime}</p>
          </div>

          <!-- Города и курорты -->
          <h2 class="text-2xl font-bold text-[var(--color-primary)] mb-6">Города и курорты</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {country.cities?.map((citySlug: string) => (
              <a 
                href={`/cities/${citySlug}`}
                class="flex items-center gap-4 p-4 bg-white border border-gray-200 rounded-xl hover:shadow-md transition-shadow"
              >
                <div class="w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center text-2xl">
                  🏙️
                </div>
                <div>
                  <h4 class="font-semibold text-[var(--color-primary)] capitalize">{citySlug.replace('-', ' ')}</h4>
                  <p class="text-sm text-gray-500">Подробнее →</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Сайдбар -->
        <aside>
          <div class="sticky top-24">
            <div class="bg-[var(--color-primary)] text-white rounded-xl p-6 mb-6">
              <h3 class="text-xl font-bold mb-4">Хотите в {country.name}?</h3>
              <p class="text-gray-300 mb-6">Оставьте заявку, и мы подберём лучший тур</p>
              <a 
                href="#request-form"
                class="block text-center bg-[var(--color-secondary)] py-3 rounded-lg font-semibold hover:bg-[var(--color-secondary)]/90 transition-colors"
              >
                Подобрать тур
              </a>
            </div>

            <!-- Быстрые факты -->
            <div class="bg-white border border-gray-200 rounded-xl p-6">
              <h3 class="font-bold text-[var(--color-primary)] mb-4">Быстрые факты</h3>
              <ul class="space-y-3 text-sm">
                <li class="flex justify-between">
                  <span class="text-gray-500">Лучшее время:</span>
                  <span class="font-medium">{country.bestTime?.split('(')[0]?.trim()}</span>
                </li>
                <li class="flex justify-between">
                  <span class="text-gray-500">Курортов:</span>
                  <span class="font-medium">{country.cities?.length || 0}</span>
                </li>
                <li class="flex justify-between">
                  <span class="text-gray-500">Виза:</span>
                  <span class="font-medium">Уточняйте</span>
                </li>
              </ul>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <RequestForm source={`country-${country.slug}`} />
</Layout>

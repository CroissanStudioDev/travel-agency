---
import Layout from '../layouts/Layout.astro'
import RequestForm from '../components/RequestForm.astro'

const services = [
  {
    id: 'tours',
    icon: '✈️',
    title: 'Подбор туров',
    description: 'Индивидуальный подбор туров под ваши пожелания и бюджет. Работаем с проверенными туроператорами.',
    features: [
      'Пляжный отдых',
      'Экскурсионные туры',
      'Горнолыжные курорты',
      'Круизы',
      'Свадебные путешествия',
      'Отдых с детьми'
    ]
  },
  {
    id: 'visa',
    icon: '📋',
    title: 'Визовая поддержка',
    description: 'Помогаем с оформлением виз в любые страны мира. Консультируем по документам и срокам.',
    features: [
      'Шенгенские визы',
      'Визы в США, Канаду, Великобританию',
      'Визы в страны Азии',
      'Срочное оформление',
      'Консультации по документам',
      'Сопровождение в визовый центр'
    ]
  },
  {
    id: 'transfer',
    icon: '🚗',
    title: 'Трансферы',
    description: 'Организуем комфортные трансферы из аэропорта до отеля и обратно в любой точке мира.',
    features: [
      'Встреча в аэропорту с табличкой',
      'Индивидуальные трансферы',
      'Групповые трансферы',
      'Аренда авто с водителем',
      'VIP-трансферы',
      'Трансферы на мероприятия'
    ]
  },
  {
    id: 'insurance',
    icon: '🛡️',
    title: 'Страхование',
    description: 'Оформляем туристические страховки от ведущих страховых компаний.',
    features: [
      'Медицинское страхование',
      'Страхование от невыезда',
      'Страхование багажа',
      'Страхование для спорта',
      'Страхование для беременных',
      'Годовые полисы для частых путешественников'
    ]
  },
  {
    id: 'vip',
    icon: '👑',
    title: 'VIP-сервис',
    description: 'Премиальное обслуживание для самых взыскательных путешественников.',
    features: [
      'Персональный менеджер 24/7',
      'Бизнес-залы в аэропортах',
      'Приоритетная регистрация и посадка',
      'Бронирование лучших номеров',
      'Частные экскурсии',
      'Консьерж-сервис на отдыхе'
    ]
  },
  {
    id: 'corporate',
    icon: '💼',
    title: 'Корпоративный туризм',
    description: 'Организация деловых поездок, конференций и корпоративных мероприятий.',
    features: [
      'Командировки сотрудников',
      'MICE-туризм',
      'Корпоративные выезды',
      'Инсентив-туры',
      'Выставки и конференции',
      'Тимбилдинги за рубежом'
    ]
  }
]
---

<Layout title="Услуги" description="Полный спектр туристических услуг — подбор туров, визы, трансферы, страхование и VIP-сервис.">
  
  <!-- Hero -->
  <section class="bg-[var(--color-primary)] text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Наши услуги</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Полный спектр услуг для комфортного путешествия
      </p>
    </div>
  </section>

  <!-- Услуги -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {services.map((service, index) => (
          <div id={service.id} class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="flex items-center gap-4 mb-4">
                <span class="text-5xl">{service.icon}</span>
                <h2 class="text-3xl font-bold text-[var(--color-primary)]">{service.title}</h2>
              </div>
              <p class="text-gray-700 text-lg mb-6">{service.description}</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {service.features.map(feature => (
                  <li class="flex items-center gap-2 text-gray-600">
                    <svg class="w-5 h-5 text-[var(--color-secondary)]" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <a 
                href="#request-form" 
                class="inline-flex mt-6 bg-[var(--color-secondary)] text-white px-6 py-3 rounded-lg font-medium hover:bg-[var(--color-secondary)]/90 transition-colors"
              >
                Заказать услугу
              </a>
            </div>
            <div class={`bg-[var(--color-light)] rounded-2xl p-8 ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="text-center">
                <span class="text-8xl">{service.icon}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Почему мы -->
  <section class="py-16 bg-[var(--color-light)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-[var(--color-primary)] text-center mb-12">Почему выбирают нас</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl text-center">
          <div class="text-4xl mb-4">🏆</div>
          <h3 class="font-semibold text-lg mb-2">Опыт и надёжность</h3>
          <p class="text-gray-600">Работаем на рынке более [XX] лет. Тысячи довольных клиентов.</p>
        </div>
        <div class="bg-white p-6 rounded-xl text-center">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="font-semibold text-lg mb-2">Лучшие цены</h3>
          <p class="text-gray-600">Прямые контракты с отелями и туроператорами.</p>
        </div>
        <div class="bg-white p-6 rounded-xl text-center">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="font-semibold text-lg mb-2">Индивидуальный подход</h3>
          <p class="text-gray-600">Каждый тур создаём под ваши пожелания.</p>
        </div>
      </div>
    </div>
  </section>

  <RequestForm source="services-page" />
</Layout>

---
interface Props {
  title: string
  subtitle?: string
  image: string
  showForm?: boolean
}

const { title, subtitle, image, showForm = false } = Astro.props
---

<section class="relative min-h-[70vh] flex items-center">
  <!-- Фон -->
  <div class="absolute inset-0">
    <img 
      src={image} 
      alt=""
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Контент -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
    <div class={showForm ? 'grid grid-cols-1 lg:grid-cols-2 gap-12 items-center' : ''}>
      <div class="text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          {title}
        </h1>
        {subtitle && (
          <p class="text-xl md:text-2xl text-gray-200 mb-8 max-w-2xl">
            {subtitle}
          </p>
        )}
        {!showForm && (
          <a 
            href="#request-form"
            class="inline-flex bg-[var(--color-secondary)] text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-[var(--color-secondary)]/90 transition-colors"
          >
            Подобрать тур
          </a>
        )}
      </div>

      {showForm && (
        <div class="bg-white rounded-2xl p-6 shadow-2xl">
          <h2 class="text-xl font-bold text-[var(--color-primary)] mb-4">Оставить заявку</h2>
          <form class="space-y-4" id="hero-form">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <input 
                  type="text" 
                  name="name" 
                  id="hero-name"
                  placeholder="Ваше имя *" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm"
                />
              </div>
              <div>
                <input 
                  type="tel" 
                  name="phone" 
                  id="hero-phone"
                  placeholder="+7 (___) ___-__-__ *" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm"
                />
              </div>
              <div>
                <input 
                  type="email" 
                  name="email" 
                  id="hero-email"
                  placeholder="Email"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm"
                />
              </div>
              <div>
                <input 
                  type="text" 
                  name="destination" 
                  id="hero-destination"
                  placeholder="Куда хотите поехать"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm"
                />
              </div>
              <div>
                <input 
                  type="text" 
                  name="dates" 
                  id="hero-dates"
                  placeholder="Даты поездки"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm"
                />
              </div>
              <div>
                <input 
                  type="number" 
                  name="people" 
                  id="hero-people"
                  placeholder="Кол-во человек"
                  min="1"
                  max="50"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm"
                />
              </div>
            </div>
            <div>
              <textarea 
                name="comment" 
                id="hero-comment"
                placeholder="Комментарий / пожелания"
                rows="2"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[var(--color-secondary)] outline-none text-sm resize-none"
              ></textarea>
            </div>
            <div class="flex items-start gap-2">
              <input 
                type="checkbox" 
                id="hero-consent" 
                name="consent" 
                required
                class="mt-1 w-4 h-4 text-[var(--color-secondary)] border-gray-300 rounded"
              />
              <label for="hero-consent" class="text-xs text-gray-600">
                Согласен на <a href="/privacy" class="text-[var(--color-primary)] hover:underline">обработку данных</a>
              </label>
            </div>
            <button 
              type="submit"
              class="w-full bg-[var(--color-secondary)] text-white py-3 rounded-lg font-semibold hover:bg-[var(--color-secondary)]/90 transition-colors"
            >
              Отправить заявку
            </button>
          </form>
          <div id="hero-form-success" class="hidden text-center py-6">
            <div class="text-4xl mb-2">✈️</div>
            <p class="font-semibold text-[var(--color-primary)]">Заявка отправлена!</p>
            <p class="text-sm text-gray-600">Мы скоро свяжемся с вами</p>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  // Маска телефона для hero-формы
  const heroPhone = document.getElementById('hero-phone') as HTMLInputElement
  if (heroPhone) {
    heroPhone.addEventListener('focus', () => {
      if (!heroPhone.value) heroPhone.value = '+7 ('
    })
    
    heroPhone.addEventListener('input', (e) => {
      let value = (e.target as HTMLInputElement).value.replace(/\D/g, '')
      if (value.length > 0) {
        if (value[0] === '8') value = '7' + value.slice(1)
        if (value[0] !== '7') value = '7' + value
      }
      let formatted = ''
      if (value.length > 0) formatted = '+7'
      if (value.length > 1) formatted += ' (' + value.slice(1, 4)
      if (value.length > 4) formatted += ') ' + value.slice(4, 7)
      if (value.length > 7) formatted += '-' + value.slice(7, 9)
      if (value.length > 9) formatted += '-' + value.slice(9, 11)
      heroPhone.value = formatted
    })

    heroPhone.addEventListener('blur', () => {
      if (heroPhone.value === '+7 (' || heroPhone.value === '+7') heroPhone.value = ''
    })
  }

  // Валидация имени — только буквы
  const heroName = document.getElementById('hero-name') as HTMLInputElement
  if (heroName) {
    heroName.addEventListener('input', (e) => {
      const input = e.target as HTMLInputElement
      input.value = input.value.replace(/[^А-Яа-яЁёA-Za-z\s\-]/g, '')
    })
  }

  // Валидация направления — только буквы
  const heroDestination = document.getElementById('hero-destination') as HTMLInputElement
  if (heroDestination) {
    heroDestination.addEventListener('input', (e) => {
      const input = e.target as HTMLInputElement
      input.value = input.value.replace(/[^А-Яа-яЁёA-Za-z\s\-,]/g, '')
    })
  }

  // Отправка формы
  const heroForm = document.getElementById('hero-form') as HTMLFormElement
  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    
    // Проверка телефона
    const phoneDigits = heroPhone?.value.replace(/\D/g, '') || ''
    if (phoneDigits.length < 11) {
      alert('Введите корректный номер телефона')
      return
    }

    const formData = new FormData(heroForm)
    const data = Object.fromEntries(formData)
    data.source = 'hero-form'
    data.timestamp = new Date().toISOString()
    
    try {
      const response = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      
      if (response.ok) {
        heroForm.classList.add('hidden')
        document.getElementById('hero-form-success')?.classList.remove('hidden')
      }
    } catch (error) {
      console.error('Error:', error)
      alert('Произошла ошибка. Попробуйте позже.')
    }
  })
</script>

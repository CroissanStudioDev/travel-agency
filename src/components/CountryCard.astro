---
interface Props {
  name: string
  slug: string
  image: string
  description?: string
}

const { name, slug, image, description } = Astro.props
---

<a 
  href={`/countries/${slug}`}
  class="group block bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow"
>
  <div class="relative h-48 overflow-hidden">
    <img 
      src={image} 
      alt={name}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
    <h3 class="absolute bottom-4 left-4 text-white text-xl font-bold">{name}</h3>
  </div>
  {description && (
    <div class="p-4">
      <p class="text-gray-600 text-sm line-clamp-2">{description}</p>
    </div>
  )}
</a>
